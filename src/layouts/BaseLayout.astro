---
interface Props {
  title: string;
}
const { title } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Naši Ptáci</title>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🐦</text></svg>" />
</head>
<body>
  <header class="site-header">
    <h1><a href={`${base}/`} style="color: inherit; text-decoration: none;">Naši Ptáci</a></h1>
    <nav>
      <a href={`${base}/`}>Atlas</a>
      <a href={`${base}/kviz/`}>Kvíz</a>
    </nav>
  </header>
  <main class="container">
    <slot />
  </main>
  <footer class="site-footer">
    Data z <a href="https://nasiptaci.info" target="_blank" rel="noopener">nasiptaci.info</a>
  </footer>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
